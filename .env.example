# backend API base URL
# VITE_API_BASE_URL=http://localhost:8080

# app-fe home CTA target URL
# VITE_TICKETING_URL=http://localhost:5173/ticket/login

# ticketing backend target
# serverdb -> http://<host>:8080
# compose  -> http://<host>:8081
# VITE_BACKEND_TARGET=serverdb

# optional ticketing dedicated API base URL
# VITE_TICKETING_API_BASE_URL=

# ticketing API mode
# VITE_API_MODE=live

# optional dev access token for admin flow
# VITE_DEV_ACCESS_TOKEN=

# legacy fallback API URL key used by ticketing env resolver
# VITE_API_URL=

# optional festival home URL used by ticketing auth pages
# VITE_FESTIVAL_HOME_URL=
